# ===== GitHub storage config =====
# Fine-grained or classic Personal Access Token with "Contents: Read and write"
# permission on the target repository.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where uploaded files get committed.
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-storage-repo
GITHUB_BRANCH=main

# Folder inside the repo where files are stored.
UPLOAD_PATH=uploads

# ===== App config =====
# Max upload size in MB (GitHub Contents API works best under ~25MB per file).
MAX_UPLOAD_MB=25

# Optional: a simple shared secret required to upload. Leave blank to disable.
# If set, the browser must send header  x-upload-key: <this value>
UPLOAD_KEY=

# Port (Azure App Service sets PORT automatically; keep 8080 for local).
PORT=8080

# ===== AI analysis (Azure OpenAI) =====
# Used by /api/analyze to read the course file and generate the evaluation form.
# Leave blank to disable AI analysis (upload + file list still work).
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=your-chat-deployment-name
AZURE_OPENAI_API_VERSION=2024-06-01
